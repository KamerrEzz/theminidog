FROM golang:1.23-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/stubserver ./cmd/stubserver

FROM alpine:3.21
RUN apk --no-cache add ca-certificates
COPY --from=builder /out/stubserver /usr/local/bin/stubserver
ENTRYPOINT ["stubserver"]
